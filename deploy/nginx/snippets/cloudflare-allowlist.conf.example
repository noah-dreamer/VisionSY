# =====================================================================
# Cloudflare 回源 IP 白名单（geo 模块）
# 用途：边缘服务器 443 端口只允许 CF 边缘节点回源，其余直接 444 断开。
# 引用：在 http {} 级别 include 本文件，server {} 内判断 $is_cf。
# 列表来源：https://www.cloudflare.com/ips/ （建议每季度核对一次）
# =====================================================================

geo $is_cf {
    default          0;
    173.245.48.0/20  1;
    103.21.244.0/22  1;
    103.22.200.0/22  1;
    103.31.4.0/22    1;
    141.101.64.0/18  1;
    108.162.192.0/18 1;
    190.93.240.0/20  1;
    188.114.96.0/20  1;
    197.234.240.0/22 1;
    198.41.128.0/17  1;
    162.158.0.0/15   1;
    104.16.0.0/13    1;
    104.24.0.0/14    1;
    172.64.0.0/13    1;
    131.0.72.0/22    1;
}
