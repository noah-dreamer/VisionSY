# =============================================================
# VisionSY 官网应用 环境配置示例
# 复制为 .env 后按需修改。生产环境真实密钥不入库：
#   - 官网相关密钥          ：`<SECRET_MANAGER>`
#   - ResourceSpace 客户端凭据：`<SECRET_MANAGER>`
#   - ResourceSpace 数据库   ：`<SECRET_MANAGER>`
#   - DNS 服务商 DNS API        ：`<SECRET_MANAGER>`
#   - Cloudflare SaaS Zone  ：`<SECRET_MANAGER>`
# =============================================================

APP_NAME=VisionSY
APP_ENV=local
APP_KEY=<APP_KEY>
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=zh_CN

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visionsy
DB_USERNAME=visionsy
DB_PASSWORD=<DB_PASSWORD>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=database
QUEUE_CONNECTION=database

# 本地默认 log 驱动；若使用 docker-compose 内的 Mailpit，改为：
# MAIL_MAILER=smtp
# MAIL_HOST=127.0.0.1
# MAIL_PORT=1025
MAIL_MAILER=log
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="${APP_NAME}"

# ---------------- VisionSY 专属配置 ----------------

# 可信代理 IP（仅来自这些来源的 X-Real-IP / CF-Connecting-IP / XFF 才被信任）
# 生产环境为 反向代理网关 容器内网 IP：10.0.0.30
TRUSTED_PROXY_IPS=127.0.0.1,10.0.0.30

# 内部 API 共享密钥（反向代理网关 / Nginx 调用 transfer-token 接口时使用）
# 生产真实值：`<SECRET_MANAGER>`
INTERNAL_API_SECRET=<INTERNAL_API_SECRET>

# 大文件 307 直连令牌
TRANSFER_TOKEN_TTL_SECONDS=600
TRANSFER_TOKEN_ONE_TIME=true

# 示例业务域名（部署时按实际环境修改）
VISION_RESOURCE_BASE_URL=https://media.example.com
VISION_SITE_URL=https://www.example.com
VISION_PUBLIC_SITE_URL=https://example.com
VISION_EXTERNAL_TRANSFER_BASE_URL=https://files.example.com:<GATEWAY_PORT>
VISION_LAN_TRANSFER_BASE_URL=https://files-internal.example.com:<GATEWAY_PORT>

# 种子数据默认密码（仅本地开发，生产不要执行 seed）
SEED_DEFAULT_PASSWORD=<LOCAL_DEV_PASSWORD>
# 种子创建的 ResourceSpace OAuth client secret（仅本地开发）
SEED_RS_CLIENT_SECRET=<OAUTH_CLIENT_SECRET>
