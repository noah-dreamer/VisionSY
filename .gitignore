# ============================================================
# VisionSY 仓库根 .gitignore
# 放置位置： VisionSY/.gitignore
# 作用：仓库级兜底。这里的规则对所有子目录（web/、resourcespace/、
#       deploy/、docs/）都生效，所以各子目录的 .gitignore 只需写
#       自己特有的东西。
# ============================================================

# Environment files
.env
.env.*
!.env.example

# Secrets / local configs
config.php
*.key
*.pem
*.crt
*.p12
*.pfx

# Dependencies
node_modules/
vendor/

# Laravel / runtime
storage/logs/
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
bootstrap/cache/

# Build output
public/build/
public/hot

# System/editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Backups / dumps
*.sql
*.sqlite
*.db
*.dump
*.bak
*.zip
*.7z
*.tar
*.tar.gz

# Logs
*.log